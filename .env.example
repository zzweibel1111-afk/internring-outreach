# ── Core ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:pass@localhost:5432/internring"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
# Comma-separated list of emails allowed to sign in (your M365 email)
ALLOWED_EMAILS="zach@internring.com"

# ── Gmail (Google OAuth Client — separate from the Sheets service account below) ─
# Same Google Cloud project as your Sheets setup. APIs & Services → Credentials →
# Create Credentials → OAuth client ID → Web application.
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# ── Google Sheets (Service Account) ─────────────────────────────────────
GOOGLE_SHEET_ID=""
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
# Paste the full private key; keep the \n escapes
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── AI ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ── Jobs ────────────────────────────────────────────────────────────────
# Shared secret for hitting /api/jobs/* from external cron (alternative to worker)
CRON_SECRET="generate-with: openssl rand -hex 24"

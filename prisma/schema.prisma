generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────── NextAuth ─────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  ext_expires_in    Int?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ───────────────────────── Domain ─────────────────────────

enum SchoolStatus {
  QUEUED              // imported, waiting for research
  RESEARCHING
  NEEDS_VERIFICATION  // contacts found, waiting on Zach's approval (review mode on)
  RESEARCH_FAILED
  DRAFT_CREATED
  CONTACTED           // draft was actually sent from Gmail
  FOLLOW_UP_NEEDED
  REPLIED
  INTERESTED
  DEMO_SCHEDULED
  ASKED_FOR_MORE_INFO
  WRONG_CONTACT
  OUT_OF_OFFICE
  NOT_INTERESTED
  NEEDS_ZACH_REVIEW   // positive reply: automation stops, Zach takes over
}

enum ContactCategory {
  HEAD_OF_SCHOOL
  ADVANCEMENT
  ALUMNI
  OTHER // referred contacts ("please contact Jane Smith")
}

enum ContactStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum DraftType {
  INITIAL
  FOLLOW_UP
  WRONG_CONTACT
}

enum DraftStatus {
  DRAFT // sitting in Gmail Drafts
  SENT  // detected as sent from Gmail
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

model School {
  id             String       @id @default(cuid())
  normalizedKey  String       @unique // lower(name)+state, dedupe key for CSV re-uploads
  name           String
  city           String?
  state          String?
  website        String?
  nicheUrl       String?
  timeZone       String? // Eastern | Central | Mountain | Pacific | Alaska | Hawaii (overridable)
  status         SchoolStatus @default(QUEUED)
  score          Int          @default(2)
  stopAutomation Boolean      @default(false) // true once NEEDS_ZACH_REVIEW or NOT_INTERESTED
  researchError  String?

  lastContactDate DateTime?
  lastReplyDate   DateTime?
  aiSummary       String? @db.Text
  concerns        String? @db.Text // newline-separated list
  nextSteps       String? @db.Text
  threadSummary   String? @db.Text

  contacts Contact[]
  drafts   OutreachDraft[]
  inbound  InboundMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id         String          @id @default(cuid())
  schoolId   String
  school     School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  category   ContactCategory
  name       String
  title      String?
  email      String?
  phone      String?
  extension  String?
  sourceUrl  String?
  confidence Float? // 0-1 from the research model
  status     ContactStatus   @default(PENDING_REVIEW)
  createdAt  DateTime        @default(now())

  @@index([schoolId, category])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  key       String   @unique // INITIAL | FOLLOW_UP
  name      String
  subject   String
  body      String   @db.Text // plain text or HTML with {{VARIABLES}}
  updatedAt DateTime @updatedAt
}

model OutreachDraft {
  id             String      @id @default(cuid())
  schoolId       String
  school         School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  type           DraftType
  status         DraftStatus @default(DRAFT)
  providerMessageId String      @unique // Gmail message id (stable across draft → sent)
  conversationId String? // captured once sent — the key for matching replies
  subject        String
  recipients     String // comma-separated, for display
  createdAt      DateTime    @default(now())
  sentAt         DateTime?

  @@index([conversationId])
}

model InboundMessage {
  id             String     @id @default(cuid())
  providerMessageId String     @unique
  conversationId String
  schoolId       String?
  school         School?    @relation(fields: [schoolId], references: [id])
  fromEmail      String
  fromName       String?
  receivedAt     DateTime
  bodyPreview    String?    @db.Text
  classification String? // Replied | Interested | Demo Scheduled | Asked for More Info | Wrong Contact | Out of Office | Not Interested
  sentiment      Sentiment?
  processed      Boolean    @default(false)
  createdAt      DateTime   @default(now())

  @@index([conversationId])
}

// Key/value app settings + cursors (inbox delta link, etc.)
model Setting {
  key   String @id
  value String @db.Text
}
